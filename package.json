{
  "name": "launchblitz",
  "version": "0.0.0",
  "private": true,
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:e2e": "playwright test --config e2e/playwright.config.ts",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@playwright/test": "latest",
    "turbo": "latest",
    "typescript": "^5.9.2"
  }
}
