{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ES2022"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "preserve",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowJs": false,
    "esModuleInterop": true,
    "baseUrl": ".",
    "paths": {
      "@launchblitz/db": [
        "packages/db/src/index.ts"
      ],
      "@launchblitz/ui": [
        "packages/ui/src/index.ts"
      ],
      "@launchblitz/workflow": [
        "packages/workflow/src/index.ts"
      ]
    }
  }
}
