# Shared
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/launchblitz

# Clerk (auth) — wired in issue #27
# The publishable key is PUBLIC (it ships in the browser bundle) and is safe to
# share. CLERK_SECRET_KEY is a real secret: never commit a real value. Use
# Clerk's Development-instance keys (pk_test_/sk_test_) locally, in CI, and in
# Vercel Preview; use Production-instance keys (pk_live_/sk_live_) only in Vercel
# Production. Real values live in .env.local (gitignored) / CI + Vercel secrets.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# AI providers
OPENAI_API_KEY=sk-replace_me
ANTHROPIC_API_KEY=sk-ant-replace_me
PERPLEXITY_API_KEY=pplx_replace_me

# Key vault
PROVIDER_KEY_ENCRYPTION_KEY=replace_me_random_secret
